{
  "description": "SkillStack creator checks — reminds about version bumps and skillstack.json config after git commits",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-version-bump.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
